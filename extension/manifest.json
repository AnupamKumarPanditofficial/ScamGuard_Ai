{
  "manifest_version": 3,
  "name": "ScamGuard",
  "version": "1.0",
  "description": "Automatically detects phishing or scam websites using AI analysis.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/api.js",
        "warningUI.js",
        "scanner.js",
        "content.js"
      ],
      "css": ["styles/warning.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
